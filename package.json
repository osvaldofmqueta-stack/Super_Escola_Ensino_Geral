{
  "name": "super-escola",
  "main": "expo-router/entry",
  "version": "1.0.3",
  "scripts": {
    "postinstall": "npx patch-package || true; bash scripts/pre-build-patches.sh 2>/dev/null || true",
    "web:dev": "CI=1 npx expo start --web --port 8000",
    "expo:dev": "EXPO_PACKAGER_PROXY_URL=https://$REPLIT_DEV_DOMAIN REACT_NATIVE_PACKAGER_HOSTNAME=$REPLIT_DEV_DOMAIN EXPO_PUBLIC_DOMAIN=$REPLIT_DEV_DOMAIN:5000 npx expo start --localhost",
    "server:dev": "NODE_ENV=development node_modules/.bin/tsx server/index.ts",
    "expo:start:static:build": "npx expo start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "web:build": "npx expo export -p web",
    "server:build": "esbuild server/index.ts --platform=node --bundle --format=cjs --outdir=server_dist --external:puppeteer --external:sharp --external:@mapbox/node-pre-gyp --external:canvas --external:fsevents",
    "server:prod": "NODE_ENV=production node server_dist/index.js",
    "db:migrate": "node scripts/migrate.js",
    "db:push": "npx drizzle-kit push",
    "db:seed:utilizadores": "node scripts/seed-utilizadores.js",
    "start": "npx expo start",
    "lint": "npx expo lint",
    "lint:fix": "npx expo lint --fix",
    "deploy:prod": "echo \"Deploy via GitHub Actions - push to main branch\"",
    "db:seed": "node scripts/seed-utilizadores.js",
    "db:seed:sistema": "node scripts/seed-sistema.js",
    "neon:test": "node -e \"console.log(\\\"DATABASE_URL:\\\", process.env.DATABASE_URL)\"",
    "db:backup": "node scripts/backup-neon.js export",
    "db:restore": "node scripts/backup-neon.js import",
    "db:backups": "node scripts/backup-neon.js list",
    "db:stats": "node scripts/backup-neon.js stats",
    "ota:production": "npx expo export -p web && npx eas update --channel production --message",
    "ota:preview": "npx expo export -p web && npx eas update --channel preview --message",
    "ota:publish": "node scripts/ota-publish.js",
    "cap:build": "bash scripts/build-capacitor.sh",
    "cap:sync": "npx cap sync android",
    "cap:open": "npx cap open android",
    "cap:apk:debug": "cd android && ./gradlew assembleDebug",
    "cap:apk:release": "cd android && ./gradlew assembleRelease"
  },
  "dependencies": {
    "@babel/types": "^7.29.0",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^7.6.5",

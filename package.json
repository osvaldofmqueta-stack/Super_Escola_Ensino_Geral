  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@types/express": "^5.0.6",
    "@types/react": "~19.1.10",
    "@types/web-push": "^3.6.4",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "drizzle-kit": "^0.31.10",
    "eas-cli": "^20.3.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^10.0.0",
    "patch-package": "^8.0.1",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom",
        "react-native",
        "react-native-keyboard-controller",
        "react-native-svg"
      ]
    }
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.27.7": true,
    "esbuild@0.28.1": true,
    "unrs-resolver@1.12.2": true,
    "protobufjs@7.6.4": true,
    "puppeteer@24.43.1": true
  }

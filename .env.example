# ══════════════════════════════════════════════════════
#  Super Escola (SIGA) — Variáveis de Ambiente
#  Copia este ficheiro para .env e preenche os valores
#  nano /var/www/superescola/.env
# ══════════════════════════════════════════════════════

# ── Base de Dados (OBRIGATÓRIO) ───────────────────────
# URL do Neon PostgreSQL — obtém em https://neon.tech
NEON_DATABASE_URL=postgresql://neondb_owner:SUA_PASSWORD@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Servidor ──────────────────────────────────────────
NODE_ENV=production
PORT=5000
SERVE_STATIC_WEB=1

# ── Autenticação JWT (OBRIGATÓRIO) ────────────────────
# Gera um segredo seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=COLOCA_AQUI_UM_SEGREDO_LONGO_E_ALEATORIO_MINIMO_32_CHARS

# ── Email via Resend (OBRIGATÓRIO — sem isto o OTP de login não é enviado) ────
# Chave API do Resend — obtém em https://resend.com/api-keys
RESEND_API_KEY=re_COLOCA_AQUI_A_TUA_RESEND_API_KEY
# Endereço de envio — o domínio deve estar verificado em https://resend.com/domains
EMAIL_FROM=noreply@liceun303.live

# ── Puppeteer / Geração de PDFs ───────────────────────
PUPPETEER_SKIP_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# ── Push Notifications (VAPID) ────────────────────────
VAPID_PUBLIC_KEY=BEnYIg-pnRJkYbEvLurvtUVZDCpQiTptDLnZsDkxB5fJsWOQ5iofcEqaqTokRmdmt0JOJaCtSgrGNMzBpmXJrng
VAPID_PRIVATE_KEY=COLOCA_AQUI_O_TEU_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@superescola.ao

# ── Notificações WhatsApp (opcional) ──────────────────
WHATSAPP_NOTIFY_NUMBER=244926219731

{
  "cli": {
    "version": ">= 18.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://liceun303.live",
        "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
        "PUPPETEER_SKIP_DOWNLOAD": "true",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "autoIncrement": true,
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://liceun303.live",
        "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
        "PUPPETEER_SKIP_DOWNLOAD": "true",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://liceun303.live",
        "NPM_CONFIG_REGISTRY": "https://registry.npmjs.org/",
        "PUPPETEER_SKIP_DOWNLOAD": "true",
        "EAS_SKIP_AUTO_FINGERPRINT": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
